{
  "name": "ardtire-society",
  "private": true,
  "packageManager": "pnpm@9.12.3",
  "engines": {
    "node": ">=20.11"
  },
  "scripts": {
    "dev": "concurrently -n web,studio -c cyan,magenta \"pnpm -C web dev\" \"pnpm -C studio dev\"",
    "web:dev": "pnpm -C web dev",
    "studio:dev": "pnpm -C studio dev",
    "build": "pnpm -C web build && pnpm -C studio build",
    "lint": "pnpm -C web lint && pnpm -C studio lint",
    "typecheck": "pnpm -C web typecheck && pnpm -C studio typecheck",
    "format": "prettier -w ."
  },
  "devDependencies": {
    "concurrently": "^9.0.1",
    "prettier": "^3.3.3"
  },
  "dependencies": {
    "@sanity/client": "^7.14.1",
    "@supabase/auth-helpers-nextjs": "^0.15.0",
    "@types/react": "^19.2",
    "docx": "^9.6.0",
    "next": "^16.0.0-0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "sanity": "^5.8.1",
    "solid": "link:@heroicons/react/20/solid"
  }
}
